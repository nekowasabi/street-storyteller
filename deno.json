{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "zod": "npm:zod@4.1.12",
    "@storyteller/": "./src/",
    "@storyteller/types/": "./src/type/"
  },
  "tasks": {
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "build": "bash scripts/build.sh",
    "coverage": "deno task go:coverage",
    "check": "deno task fmt:check && deno task lint && deno task test:authoring && deno task go:test",
    "bench": "deno bench --allow-read --allow-write --allow-net bench/",
    "test": "deno task test:authoring",
    "test:authoring": "deno test --allow-read tests/authoring/",
    "cli:compile": "echo 'deprecated: use scripts/build.sh for the Go storyteller binary'",
    "cli:manifest": "deno run --allow-read --allow-write scripts/build_cli.ts --out dist --artifacts dist/storyteller",
    "cli:build": "deno task cli:manifest",
    "cli:completions": "deno run --allow-read --allow-write scripts/generate_completions.ts",
    "cli:package": "deno task cli:compile && deno task cli:manifest && deno task cli:completions",
    "install": "mkdir -p ~/.local/bin && ln -sf $(pwd)/storyteller ~/.local/bin/storyteller && echo 'Installed: ~/.local/bin/storyteller'",
    "uninstall": "rm -f ~/.local/bin/storyteller && echo 'Uninstalled: ~/.local/bin/storyteller'",
    "go:test": "go test ./... -count=1",
    "go:test:integration": "go test -tags=integration ./... -count=1",
    "go:test:external": "go test -tags=external ./... -count=1 -v",
    "go:coverage": "bash scripts/go_coverage.sh"
  },
  "fmt": {
    "exclude": [
      "coverage/",
      "dist/",
      "output/",
      "test_output/",
      "internal/**/testdata/"
    ]
  },
  "exclude": ["samples/", "src/characters/", "src/settings/", "src/timelines/"],
  "lint": {
    "exclude": ["coverage/", "dist/", "output/", "test_output/", "samples/"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any", "require-await"]
    }
  }
}
